# k6-scripts env example
#
# Usage:
#   set -a; source .env; set +a
#   ./run-test.sh "$TARGET_BASE_URL" chat
#

# Target API base URL (staging instance)
TARGET_BASE_URL=http://127.0.0.1:8080

# -----------------------------
# Auth / Token strategy
# -----------------------------
# Option A (recommended for staging load tests):
# If set, k6 will call the loadtest-only token batch issuance endpoint:
#   GET /api/v1/auth/test/tokens?count=N
#   Header: X-Test-Secret: <LOADTEST_SECRET>
# and distribute tokens across VUs.
LOADTEST_SECRET=
# Optional: override number of tokens to request (defaults to VUS)
TOKEN_COUNT=

# Option B: single token
ACCESS_TOKEN=
# Option C: refresh token (k6 will call /api/v1/auth/kakao/refresh in setup)
REFRESH_TOKEN=

# Option D: pre-issued token pool (comma-separated)
# ACCESS_TOKENS=token1,token2,token3,...
ACCESS_TOKENS=

# -----------------------------
# Load parameters
# -----------------------------
VUS=10
DURATION=30s
THINK_TIME_MS=200
DEBUG=false

# -----------------------------
# Evaluation polling (used by application-eval scenario)
# -----------------------------
EVAL_POLL_ATTEMPTS=5
EVAL_POLL_INTERVAL_MS=500
